# Database
POSTGRES_USER=supkeys
POSTGRES_PASSWORD=changeme
POSTGRES_DB=supkeys
POSTGRES_PORT=5432
DATABASE_URL=postgresql://supkeys:changeme@localhost:5432/supkeys?schema=public

# Redis
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# MinIO (S3-compatible object storage)
MINIO_ROOT_USER=supkeys
MINIO_ROOT_PASSWORD=changeme
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=supkeys-dev

# API
API_PORT=4000
API_URL=http://localhost:4000
JWT_SECRET=change_me_in_production_minimum_32_chars_long
JWT_EXPIRES_IN=7d

# CORS — virgülle ayrılmış origin'ler
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Web (tenant)
WEB_PORT=3000
WEB_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Admin
ADMIN_PORT=3001
ADMIN_URL=http://localhost:3001

# Node
NODE_ENV=development

# Initial Platform Admin (seed only)
INITIAL_ADMIN_EMAIL=admin@supkeys.com
INITIAL_ADMIN_PASSWORD=changeme
INITIAL_ADMIN_FIRST_NAME=Supkeys
INITIAL_ADMIN_LAST_NAME=Admin

# Resend (e-posta)
RESEND_API_KEY=re_xxx
EMAIL_FROM_NAME=Supkeys
EMAIL_FROM_ADDRESS=onboarding@resend.dev
EMAIL_REPLY_TO=

# E-posta provider seçimi: "mailpit" (lokal) veya "resend" (gerçek gönderim)
EMAIL_PROVIDER=mailpit

# Mailpit (lokal SMTP yakalayıcı — http://localhost:8025 web UI)
MAILPIT_HOST=localhost
MAILPIT_PORT=1025

