# Database
POSTGRES_USER=supkeys
POSTGRES_PASSWORD=supkeys_dev_password
POSTGRES_DB=supkeys
POSTGRES_PORT=5432
DATABASE_URL=postgresql://supkeys:supkeys_dev_password@localhost:5432/supkeys?schema=public

# Redis
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# MinIO (S3-compatible object storage)
MINIO_ROOT_USER=supkeys
MINIO_ROOT_PASSWORD=supkeys_dev_password
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=supkeys-dev

# API
API_PORT=4000
API_URL=http://localhost:4000
JWT_SECRET=change_me_in_production_minimum_32_chars_long
JWT_EXPIRES_IN=7d

# Web
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Node
NODE_ENV=development

# Initial Platform Admin (seed only)
INITIAL_ADMIN_EMAIL=admin@supkeys.com
INITIAL_ADMIN_PASSWORD=admin12345
INITIAL_ADMIN_FIRST_NAME=Supkeys
INITIAL_ADMIN_LAST_NAME=Admin
