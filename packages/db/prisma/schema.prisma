generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// SUPKEYS — Çekirdek Şema
// ============================================================

// ---------- TENANT TARAFI (müşteri firmalar) ----------

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)

  // Firma profili (registration sırasında dolar)
  industry    String?
  city        String?
  district    String?
  addressLine String?
  postalCode  String?
  taxNumber   String? @unique
  taxOffice   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                User[]
  buyerApplication     BuyerApplication?       @relation("BuyerAppTenant")
  supplierInvitations  SupplierInvitation[]
  supplierRelations    SupplierTenantRelation[]
  invitedSupplierApps  SupplierApplication[]   @relation("SupplierAppInviter")
  tenders              Tender[]
  orders               Order[]

  @@map("tenants")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  firstName    String
  lastName     String
  role         UserRole  @default(BUYER)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  sentSupplierInvitations SupplierInvitation[]
  tendersCreated          Tender[]                  @relation("TendersCreated")

  @@index([tenantId])
  @@map("users")
}

enum UserRole {
  COMPANY_ADMIN
  BUYER
  APPROVER
}

// ---------- PLATFORM TARAFI (Supkeys ekibi) ----------

model PlatformAdmin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  role         AdminRole @default(SUPPORT)
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignedDemoRequests         DemoRequest[]
  reviewedBuyerApplications    BuyerApplication[]    @relation("BuyerAppReviewer")
  reviewedSupplierApplications SupplierApplication[] @relation("SupplierAppReviewer")

  @@map("platform_admins")
}

enum AdminRole {
  SUPER_ADMIN  // her şey
  SALES        // demo, tenant
  SUPPORT      // sadece okuma + tenant impersonate
}

// ---------- LEAD / DEMO TALEPLERİ ----------

model DemoRequest {
  id           String            @id @default(cuid())
  companyName  String
  contactName  String
  email        String
  phone        String?
  jobTitle     String?
  companySize  String?
  message      String?
  status       DemoRequestStatus @default(NEW)
  source       String?
  notes        String?
  contactedAt  DateTime?
  closedAt     DateTime?
  closedReason String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  assignedToId String?
  assignedTo   PlatformAdmin? @relation(fields: [assignedToId], references: [id], onDelete: SetNull)

  // ---------- DAVET (admin → demo görüşmesinden sonra kayıt linki) ----------
  inviteToken       String?   @unique // sha256 hash; ham token sadece e-postada
  inviteSentAt      DateTime?
  inviteSentToEmail String? // davet hangi e-postaya gönderildi (demo.email'den farklı olabilir)
  inviteSentMessage String? // admin'in kişisel notu
  inviteTokenExpAt  DateTime?
  inviteUsedAt      DateTime? // tek kullanımlık
  inviteSentCount   Int       @default(0)

  // Davetten kayıt akışı tamamlanınca bağlanan başvuru
  linkedApplicationId String?           @unique
  linkedApplication   BuyerApplication? @relation("DemoToBuyerApp", fields: [linkedApplicationId], references: [id])

  @@index([status])
  @@index([assignedToId])
  @@index([createdAt])
  @@map("demo_requests")
}

enum DemoRequestStatus {
  NEW
  CONTACTED
  DEMO_SCHEDULED
  DEMO_DONE
  WON
  LOST
  SPAM
}

// ---------- E-POSTA LOGLARI ----------

model EmailLog {
  id                String      @id @default(cuid())
  template          String
  toEmail           String
  toName            String?
  subject           String
  provider          String
  providerMessageId String?
  status            EmailStatus @default(QUEUED)
  errorMessage      String?
  payload           Json?
  attemptCount      Int         @default(0)
  queuedAt          DateTime    @default(now())
  sentAt            DateTime?
  failedAt          DateTime?

  contextType String?
  contextId   String?

  @@index([status])
  @@index([toEmail])
  @@index([template])
  @@index([contextType, contextId])
  @@index([queuedAt])
  @@map("email_logs")
}

enum EmailStatus {
  QUEUED
  SENDING
  SENT
  FAILED
}

// ============================================================
// REGISTRATION & APPLICATIONS
// ============================================================

model BuyerApplication {
  id              String              @id @default(cuid())

  companyName     String
  companyType     CompanyType
  taxNumber       String
  taxOffice       String
  taxCertUrl      String
  industry        String?
  website         String?

  city            String
  district        String
  addressLine     String
  postalCode      String?

  adminFirstName  String
  adminLastName   String
  adminEmail      String
  adminPhone      String?
  passwordHash    String

  status          ApplicationStatus   @default(PENDING_EMAIL_VERIFICATION)

  emailToken      String?             @unique
  emailTokenExp   DateTime?
  emailVerifiedAt DateTime?

  reviewedById    String?
  reviewedBy      PlatformAdmin?      @relation("BuyerAppReviewer", fields: [reviewedById], references: [id])
  reviewedAt      DateTime?
  rejectionReason String?

  tenantId        String?             @unique
  tenant          Tenant?             @relation("BuyerAppTenant", fields: [tenantId], references: [id])

  // Demo görüşmesi sonrası gönderilen davetle mi geldi?
  fromDemoRequest DemoRequest?        @relation("DemoToBuyerApp")

  ipAddress       String?
  userAgent       String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@unique([adminEmail, status])
  @@index([status])
  @@index([adminEmail])
  @@index([createdAt])
  @@map("buyer_applications")
}

model SupplierApplication {
  id              String              @id @default(cuid())

  companyName     String
  companyType     CompanyType
  taxNumber       String
  taxOffice       String
  taxCertUrl      String
  industry        String?
  website         String?

  city            String
  district        String
  addressLine     String
  postalCode      String?

  adminFirstName  String
  adminLastName   String
  adminEmail      String
  adminPhone      String?
  passwordHash    String

  status          ApplicationStatus   @default(PENDING_EMAIL_VERIFICATION)

  emailToken      String?             @unique
  emailTokenExp   DateTime?
  emailVerifiedAt DateTime?

  invitationId      String?             @unique
  invitation        SupplierInvitation? @relation(fields: [invitationId], references: [id])
  invitedByTenantId String?
  invitedByTenant   Tenant?             @relation("SupplierAppInviter", fields: [invitedByTenantId], references: [id])

  reviewedById    String?
  reviewedBy      PlatformAdmin?      @relation("SupplierAppReviewer", fields: [reviewedById], references: [id])
  reviewedAt      DateTime?
  rejectionReason String?

  supplierId      String?             @unique
  supplier        Supplier?           @relation("SupplierAppSupplier", fields: [supplierId], references: [id])

  ipAddress       String?
  userAgent       String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([status])
  @@index([adminEmail])
  @@index([invitedByTenantId])
  @@index([createdAt])
  @@map("supplier_applications")
}

enum ApplicationStatus {
  PENDING_EMAIL_VERIFICATION
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum CompanyType {
  JOINT_STOCK
  LIMITED
  SOLE_PROPRIETOR
}

// ============================================================
// SUPPLIER (gerçek tedarikçi entitysi)
// ============================================================

model Supplier {
  id            String             @id @default(cuid())
  companyName   String
  companyType   CompanyType
  taxNumber     String             @unique
  taxOffice     String
  taxCertUrl    String
  industry      String?
  website       String?
  city          String
  district      String
  addressLine   String
  postalCode    String?
  membership    SupplierMembership @default(STANDARD)
  isActive      Boolean            @default(true)
  isBlocked     Boolean            @default(false)
  blockedReason String?
  blockedAt     DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  users               SupplierUser[]
  tenantRelations     SupplierTenantRelation[]
  application         SupplierApplication?      @relation("SupplierAppSupplier")
  invitationsAccepted SupplierInvitation[]      @relation("AcceptedBySupplier")
  tenderInvitations   TenderInvitation[]
  bids                Bid[]
  orders              Order[]

  @@index([taxNumber])
  @@index([membership])
  @@map("suppliers")
}

enum SupplierMembership {
  STANDARD // Davet ile veya self-register, ücretsiz (eski adı: BRONZE)
  PREMIUM  // Havuza açık, ücretli (V2'de aktif olur, eski adı: SILVER)
}

model SupplierUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  bidsSubmitted Bid[]

  @@index([supplierId])
  @@map("supplier_users")
}

model SupplierTenantRelation {
  id            String         @id @default(cuid())
  supplierId    String
  supplier      Supplier       @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  tenantId      String
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  status        RelationStatus @default(ACTIVE)
  blockedAt     DateTime?
  blockedReason String?
  createdAt     DateTime       @default(now())

  @@unique([supplierId, tenantId])
  @@index([tenantId])
  @@index([supplierId])
  @@map("supplier_tenant_relations")
}

enum RelationStatus {
  ACTIVE
  PENDING_TENANT_APPROVAL
  BLOCKED
}

// ============================================================
// SUPPLIER INVITATIONS (alıcı → tedarikçi davetleri)
// ============================================================

model SupplierInvitation {
  id              String           @id @default(cuid())
  tenantId        String
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invitedByUserId String
  invitedByUser   User             @relation(fields: [invitedByUserId], references: [id])

  email           String
  contactName     String?
  message         String?

  tokenHash       String           @unique
  expiresAt       DateTime

  status          InvitationStatus @default(PENDING)
  acceptedAt      DateTime?
  cancelledAt     DateTime?
  acceptedBySupplierId String?
  acceptedBySupplier   Supplier?  @relation("AcceptedBySupplier", fields: [acceptedBySupplierId], references: [id])

  sentCount  Int      @default(1)
  lastSentAt DateTime @default(now())

  // Multi-tenant tedarikçi davet kabul akışı (D.2.B)
  // Davet oluşturulurken: e-posta zaten aktif bir SupplierUser'a aitse true.
  // Mevcut tedarikçi /supplier/profil üzerinden, yeni tedarikçi /register/supplier üzerinden kabul eder.
  isExistingSupplier Boolean @default(false)
  // Kullanıcının e-posta dışında manuel girebilmesi için kısa kod (Crockford Base32 4-4: K7X9-3M2P).
  // Legacy satırlarda NULL kalabilir; yeni davetlerde her zaman üretilir.
  shortCode  String?  @unique
  // Davet linki ilk açıldığında set edilir; alıcı tarafa "açıldı/açılmadı" göstergesi için.
  openedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  application SupplierApplication?

  @@index([tenantId])
  @@index([email])
  @@index([status])
  @@index([expiresAt])
  @@map("supplier_invitations")
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

// ============================================================
// TENDER MODULE — Aşama E
// ============================================================

enum TenderType {
  RFQ                  // Request for Quotation (kapalı teklif)
  ENGLISH_AUCTION      // İngiliz usulü açık eksiltme (V2)
}

enum TenderStatus {
  DRAFT                // Taslak (henüz yayınlanmadı)
  OPEN_FOR_BIDS        // Yayında, teklif alıyor
  IN_AWARD             // Süre doldu, alıcı kazandırma yapıyor
  AWARDED              // Kazandırıldı, sipariş oluştu
  CANCELLED            // İptal edildi
  CLOSED_NO_AWARD      // Süre doldu, kazandırma yapılmadı
}

enum Currency {
  TRY
  USD
  EUR
}

enum DeliveryTerm {
  EXW
  FCA
  CPT
  CIP
  DAP
  DPU
  DDP
  FAS
  FOB
  CFR
  CIF
}

enum PaymentTerm {
  CASH                 // Peşin
  DEFERRED             // Vadeli
}

enum TenderInvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum BidStatus {
  DRAFT
  SUBMITTED
  WITHDRAWN
  REJECTED
  AWARDED_PARTIAL
  AWARDED_FULL
  LOST
}

enum OrderStatus {
  PENDING
  ACCEPTED
  IN_PROGRESS
  DELIVERED
  COMPLETED
  CANCELLED
}

model Tender {
  id                  String          @id @default(cuid())

  tenantId            String
  tenant              Tenant          @relation(fields: [tenantId], references: [id])
  createdById         String
  createdBy           User            @relation("TendersCreated", fields: [createdById], references: [id])

  tenderNumber        String          @unique
  type                TenderType      @default(RFQ)
  status              TenderStatus    @default(DRAFT)

  title               String
  description         String?
  termsAndConditions  String?
  internalNotes       String?

  isSealedBid         Boolean         @default(true)
  requireAllItems     Boolean         @default(false)
  requireBidDocument  Boolean         @default(false)

  primaryCurrency     Currency        @default(TRY)
  allowedCurrencies   Currency[]      @default([TRY])
  decimalPlaces       Int             @default(2)

  deliveryTerm        DeliveryTerm?
  deliveryAddress     String?

  paymentTerm         PaymentTerm     @default(CASH)
  paymentDays         Int?

  publishedAt         DateTime?
  bidsOpenAt          DateTime?
  bidsCloseAt         DateTime
  awardedAt           DateTime?
  cancelledAt         DateTime?
  cancelReason        String?

  items               TenderItem[]
  invitations         TenderInvitation[]
  bids                Bid[]
  orders              Order[]
  attachments         TenderAttachment[]

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([tenantId, status])
  @@index([status, bidsCloseAt])
  @@map("tenders")
}

model TenderItem {
  id                  String          @id @default(cuid())
  tenderId            String
  tender              Tender          @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  orderIndex          Int
  name                String
  description         String?

  quantity            Decimal         @db.Decimal(15, 4)
  unit                String

  materialCode        String?
  requiredByDate      DateTime?
  targetUnitPrice     Decimal?        @db.Decimal(15, 4)

  customQuestion      String?

  bidItems            BidItem[]

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([tenderId, orderIndex])
  @@map("tender_items")
}

model TenderInvitation {
  id                  String                @id @default(cuid())
  tenderId            String
  tender              Tender                @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  supplierId          String
  supplier            Supplier              @relation(fields: [supplierId], references: [id])

  status              TenderInvitationStatus @default(PENDING)
  invitedAt           DateTime              @default(now())
  respondedAt         DateTime?

  emailSentAt         DateTime?
  emailOpenedAt       DateTime?

  @@unique([tenderId, supplierId])
  @@index([supplierId, status])
  @@map("tender_invitations")
}

model Bid {
  id                  String          @id @default(cuid())
  tenderId            String
  tender              Tender          @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  supplierId          String
  supplier            Supplier        @relation(fields: [supplierId], references: [id])
  submittedById       String
  submittedBy         SupplierUser    @relation(fields: [submittedById], references: [id])

  status              BidStatus       @default(DRAFT)

  currency            Currency
  totalAmount         Decimal         @db.Decimal(20, 4)

  notes               String?
  version             Int             @default(1)

  submittedAt         DateTime?
  withdrawnAt         DateTime?

  items               BidItem[]
  attachments         BidAttachment[]
  orders              Order[]

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@unique([tenderId, supplierId])
  @@index([tenderId, status])
  @@map("bids")
}

model BidItem {
  id                  String          @id @default(cuid())
  bidId               String
  bid                 Bid             @relation(fields: [bidId], references: [id], onDelete: Cascade)
  tenderItemId        String
  tenderItem          TenderItem      @relation(fields: [tenderItemId], references: [id])

  unitPrice           Decimal?        @db.Decimal(15, 4)
  totalPrice          Decimal?        @db.Decimal(20, 4)
  currency            Currency

  customAnswer        String?

  isWinner            Boolean         @default(false)
  awardedQuantity     Decimal?        @db.Decimal(15, 4)

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@unique([bidId, tenderItemId])
  @@map("bid_items")
}

model BidAttachment {
  id                  String          @id @default(cuid())
  bidId               String
  bid                 Bid             @relation(fields: [bidId], references: [id], onDelete: Cascade)

  fileName            String
  fileSize            Int
  mimeType            String
  fileUrl             String

  uploadedAt          DateTime        @default(now())

  @@map("bid_attachments")
}

model TenderAttachment {
  id                  String          @id @default(cuid())
  tenderId            String
  tender              Tender          @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  fileName            String
  fileSize            Int
  mimeType            String
  fileUrl             String

  uploadedAt          DateTime        @default(now())

  @@map("tender_attachments")
}

model Order {
  id                  String          @id @default(cuid())
  orderNumber         String          @unique

  tenderId            String
  tender              Tender          @relation(fields: [tenderId], references: [id])
  tenantId            String
  tenant              Tenant          @relation(fields: [tenantId], references: [id])
  supplierId          String
  supplier            Supplier        @relation(fields: [supplierId], references: [id])
  bidId               String
  bid                 Bid             @relation(fields: [bidId], references: [id])

  status              OrderStatus     @default(PENDING)

  currency            Currency
  totalAmount         Decimal         @db.Decimal(20, 4)

  expectedDeliveryAt  DateTime?
  deliveredAt         DateTime?

  notes               String?

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([tenantId, status])
  @@index([supplierId, status])
  @@map("orders")
}
